# Supabase (local — from `supabase status`)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<from-supabase-status>
SUPABASE_SERVICE_ROLE_KEY=<from-supabase-status>
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ML service
ML_SERVICE_URL=http://127.0.0.1:8000

# Email (nodemailer → Mailpit in dev, Resend in prod)
SMTP_HOST=localhost
SMTP_PORT=1025
EMAIL_FROM=noreply@salvacao.local
RESEND_API_KEY=re_placeholder

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Chip encryption — generate: openssl rand -base64 32
APP_CHIP_ENCRYPTION_KEY=<generate-with-openssl-rand-base64-32>

# Bot / internal API (shared between web app and bot)
# Generate: openssl rand -hex 32
INTERNAL_API_TOKEN=<generate-with-openssl-rand-hex-32>

# Notifications
ADMIN_EMAIL=<admin email address>
ADMIN_TELEGRAM_ID=<admin numeric Telegram chat ID — get from @userinfobot>
TELEGRAM_BOT_TOKEN=<same token as the bot — used to send proactive messages>

# Node env
NODE_ENV=development
